use Mix.Config

# Copy this file to config/dev.local.exs (gitignored) and adapt for your local setup.
#
# Typical values while running the FIDO conformance app:
# - origin: your current Cloudflare quick tunnel URL
# - mds_execute_endpoints: the 5 execute URLs generated by https://mds3.fido.tools/
# - mds_skip_execute_endpoints: the one endpoint intentionally used for revoked-leaf negative tests
# - mds_root_cert_path: local path to MDS3ROOT.crt from https://mds3.fido.tools/pki/MDS3ROOT.crt
# - cors_allowed_origins: only origins allowed to call this server from browsers
#
# Note: keep this file local; do not commit private test configuration.

config :wax_, :origin, "https://your-current-tunnel.trycloudflare.com"

config :wax_, :rp_id, :auto
config :wax_, :metadata_dir, "priv/fido2_metadata/metadataStatements"
config :wax_, :tpm_allow_conformance_fake_manufacturer, true

config :wax_fido_test_suite_server, :mds_root_cert_path, "priv/fido2_metadata/MDS3ROOT.crt"
config :wax_fido_test_suite_server, :cors_allowed_origins, [
  "https://your-current-tunnel.trycloudflare.com",
  "null"
]
config :wax_fido_test_suite_server, :mds_connect_timeout_ms, 2000
config :wax_fido_test_suite_server, :mds_request_timeout_ms, 5000

config :wax_fido_test_suite_server, :mds_execute_endpoints, [
  "https://mds3.fido.tools/execute/<endpoint-1>",
  "https://mds3.fido.tools/execute/<endpoint-2>",
  "https://mds3.fido.tools/execute/<endpoint-3>",
  "https://mds3.fido.tools/execute/<endpoint-4>",
  "https://mds3.fido.tools/execute/<endpoint-5>"
]

config :wax_fido_test_suite_server, :mds_skip_execute_endpoints, [
  # The endpoint intentionally used by the conformance suite as revoked-leaf negative case.
  "https://mds3.fido.tools/execute/<revoked-leaf-endpoint>"
]
